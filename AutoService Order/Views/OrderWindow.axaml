<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:AutoService_Order.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AutoService_Order.Views.OrderWindow"
        x:DataType="viewModels:OrderWindowVIewModel"
        Title="Itog">
        
        <StackPanel>
                <Label Content="{Binding Order.CarModel}"/>
                <Label Content="{Binding Order.ClientName}"/>
                <TextBlock Text="Услуги"/>
                <ListBox ItemsSource="{Binding Works}"
                         DisplayMemberBinding="{Binding WorkName}"/>
                <Label Content="{Binding Order.OrderDate,StringFormat=dd.MM.yyyy}"/>
                <TextBlock Text="Скидка:"/>
                <Label Content="{Binding Order.DiscountPercent}"/>
                <TextBlock Text="Итог"/>
                <Label Content="{Binding Order.TotalAmount}"/>
                
        </StackPanel>
</Window>
